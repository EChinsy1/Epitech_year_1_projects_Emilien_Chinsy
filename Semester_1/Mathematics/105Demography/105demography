def main(sys):
    with open('105demography_data.csv', newline='') as csvfile:
        csvfile = csv.reader(csvfile, delimiter=';', quotechar='|')
        i = 0
        empty = 0
        country_list = []
        country = Country("BIGCOUNTRY", "BIG")

        if (len(sys.argv) == 2 and sys.argv[1] == "-h"):
           return print_help()
        if (len(sys.argv) == 1 or "INX" in sys.argv[1:]):
            return 84
        for row in csvfile:
            if (i != 0 and row[1] in sys.argv[1:]):
                country.fill_list(row, empty)
                country_list.append(row[0])
                empty += 1
            i += 1
        if (empty != len(sys.argv[1:])):
            return 84
        return print_results(country_list, country)

exit(main(sys))